%%{init: {"theme":"base","themeVariables":{
  "fontFamily":"-apple-system,Segoe UI,Roboto,Helvetica,Arial,sans-serif",
  "primaryColor":"#1f2935","primaryTextColor":"#e6edf3","primaryBorderColor":"#2b3744",
  "lineColor":"#8b98a5","clusterBkg":"#141b24","clusterBorder":"#2b3744","fontSize":"14px"
},"flowchart":{"nodeSpacing":40,"rankSpacing":55,"curve":"basis"}}}%%
flowchart TB

  %% ============================ 1. SOURCES ============================
  subgraph SRC["① SOURCES — 33 BMJ systems"]
    direction LR
    SRC_DB["Databases<br/>Salesforce · Navision · BMA CRM<br/>Learning PG · ICS"]
    SRC_SFTP["SFTP feeds<br/>Adestra · Highwire · ScholarOne<br/>HEE · SiQ · Proquest"]
    SRC_API["APIs<br/>Crossref · Dimensions · WoS<br/>ROR · Ringgold · RightsLink · Kria"]
  end

  %% =================== 2. CONNECTIVITY & TRUST ========================
  subgraph CONN["② CONNECTIVITY & TRUST BOUNDARY"]
    direction LR
    INTERCONNECT["AWS↔GCP Private Connectivity<br/>HTTPS / TLS 1.2+"]
    VPC["Private VPC (RFC1918)<br/>Cloud NAT · Private Google Access"]
    WIF["Workforce Identity Federation<br/>(Entra ID / AD SSO)"]
    VPCSC["VPC Service Controls<br/>perimeter + allowlists"]
  end

  %% ======================= 3. GCP DATA PLATFORM =======================
  subgraph PLAT["③ GCP DATA PLATFORM — isolated DEV / TEST / PROD projects"]
    direction TB
    AIRBYTE["Airbyte on GKE Autopilot<br/>ingestion / EL"]
    GCS["GCS data lake<br/>landing → staging → archive"]
    RAW["BigQuery: raw / bronze"]
    DBT["dbt on Cloud Build<br/>transform"]
    SILVER["BigQuery: silver"]
    GOLD["BigQuery: gold (marts)"]
    REF["BigQuery: reference"]
    COMPOSER["Cloud Composer + Workflows<br/>orchestration"]
    CATALOG["Dataplex catalog"]

    AIRBYTE --> GCS --> RAW --> DBT --> SILVER --> DBT2["dbt"] --> GOLD
    REF --> SILVER
    COMPOSER -. orchestrates .-> AIRBYTE
    COMPOSER -. orchestrates .-> DBT
    GOLD -. lineage .-> CATALOG
  end

  %% =========================== 4. CONSUMPTION =========================
  subgraph CONS["④ CONSUMPTION"]
    direction LR
    TABLEAU["Tableau<br/>dashboards"]
    HUM["Hum<br/>reporting & insights"]
    APPS["Third-party apps<br/>portals · APIs"]
    VERTEX["Vertex AI ML<br/>future scope"]
  end

  %% ===================== CROSS-CUTTING GOVERNANCE =====================
  subgraph GOV["GOVERNANCE & SECURITY (cross-cutting)"]
    direction LR
    KMS["Cloud KMS · CMEK"]
    SECRETS["Secret Manager"]
    DLP["DLP / PII handling"]
    AUDIT["Cloud Monitoring<br/>audit logs · budgets"]
  end

  %% ----------------------------- FLOWS --------------------------------
  SRC ==> CONN
  CONN ==> PLAT
  PLAT ==> CONS
  GOV -. guards .-> PLAT

  %% ----------------------------- STYLES -------------------------------
  classDef src fill:#E8743B,stroke:#b5571f,color:#fff;
  classDef conn fill:#E8743B,stroke:#b5571f,color:#fff;
  classDef plat fill:#C0392B,stroke:#8c2a20,color:#fff;
  classDef cons fill:#4F8DF0,stroke:#2f6fd0,color:#fff;
  classDef gov fill:#243140,stroke:#3FB950,color:#e6edf3;

  class SRC_DB,SRC_SFTP,SRC_API src;
  class INTERCONNECT,VPC,WIF,VPCSC conn;
  class AIRBYTE,GCS,RAW,SILVER,GOLD,REF,DBT,DBT2,COMPOSER,CATALOG plat;
  class TABLEAU,HUM,APPS,VERTEX cons;
  class KMS,SECRETS,DLP,AUDIT gov;

  %% ------------------- LINKS TO INFRASTRUCTURE-AS-CODE -------------------
